{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:filename((?!docs$|docs\\.html$).*)",
      "destination": "https://huggingface.co/datasets/notamitgamer/uploads/resolve/main/:filename",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/batch/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/docs",
      "destination": "/docs.html"
    }
  ]
}
