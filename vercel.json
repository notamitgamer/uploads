{
  "redirects": [
    {
      "source": "/:filename((?!docs$|docs\\.html$|index\\.html$)[^/]+)",
      "destination": "https://huggingface.co/datasets/notamitgamer/uploads/resolve/main/:filename",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/api/index"
    },
    {
      "source": "/batch/:match*",
      "destination": "/api/index"
    },
    {
      "source": "/docs",
      "destination": "/docs.html"
    }
  ]
}
